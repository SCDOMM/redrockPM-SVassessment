<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv1_video_item"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintDimensionRatio="W,1:5"
        app:layout_constraintTop_toTopOf="parent ">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_video_author_item"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="10dp"
                android:padding="2dp"
                android:src="@drawable/eyepetater"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="W,1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/round"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/tv_video_name_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="测试测试"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/iv_video_author_item"
                app:layout_constraintTop_toTopOf="@id/iv_video_author_item" />


            <TextView
                android:id="@+id/tv_video_time_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1919.8.10"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/iv_video_author_item"
                app:layout_constraintStart_toStartOf="@id/tv_video_name_item" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv2_video_item"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintDimensionRatio="W,9:16"
        app:layout_constraintTop_toBottomOf="@id/cv1_video_item">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_video_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/eyepetater_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_person_play"
                app:layout_constraintBottom_toBottomOf="@id/iv_video_cover"
                app:layout_constraintEnd_toEndOf="@id/iv_video_cover"
                app:layout_constraintStart_toStartOf="@id/iv_video_cover"
                app:layout_constraintTop_toTopOf="@id/iv_video_cover" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv3_video_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cv2_video_item">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/tv_video_desc_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="你说的对，但是3G芯片是由重庆邮电大学自主研发..."
                android:textColor="#000000"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"

                />
            <TextView
                android:id="@+id/tv_video_fold_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:text="展开"
                app:layout_constraintTop_toBottomOf="@id/tv_video_desc_item"
                app:layout_constraintEnd_toEndOf="parent"
                />

            <TextView
                android:id="@+id/tv_video_label_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="#标签"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_video_fold_item" />
            <ImageView
                android:id="@+id/iv_video_topic_item"
                android:src="@drawable/ic_person_topic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_video_label_item"
                />
            <TextView
                android:id="@+id/tv_video_topic_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="#话题"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/iv_video_topic_item"
                app:layout_constraintTop_toBottomOf="@id/tv_video_label_item" />




            <ImageView
                android:id="@+id/iv_video_like_item"
                android:src="@drawable/ic_person_like"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_video_topic_item"

                app:layout_constraintStart_toStartOf="parent"
                />
            <TextView
                android:id="@+id/tv_video_like_item"
                android:text="114"
                android:textSize="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_video_topic_item"
                app:layout_constraintStart_toEndOf="@id/iv_video_like_item"
                />
            <ImageView
                android:id="@+id/iv_video_favor_item"
                android:src="@drawable/ic_person_favor"
                android:layout_marginStart="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_video_topic_item"
                app:layout_constraintStart_toEndOf="@id/tv_video_like_item"
                />
            <TextView
                android:id="@+id/tv_video_favor_item"
                android:text="114"
                android:textSize="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_video_topic_item"
                app:layout_constraintStart_toEndOf="@id/iv_video_favor_item"
                />
            <ImageView
                android:id="@+id/iv_video_comment_item"
                android:src="@drawable/ic_person_comment"
                android:layout_width="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_video_topic_item"
                app:layout_constraintStart_toEndOf="@id/tv_video_favor_item"
                />
            <TextView
                android:id="@+id/tv_video_comment_item"
                android:text="114"
                android:textSize="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_video_label_item"
                app:layout_constraintStart_toEndOf="@id/iv_video_comment_item"
                />
            <ImageView
                android:id="@+id/iv_video_forward_item"
                android:src="@drawable/ic_person_forward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/tv_video_topic_item"
                app:layout_constraintEnd_toEndOf="parent"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>