<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="3dp"
    >

    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv_new_item_item"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintDimensionRatio="W,9:16"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_new_cover_item_item"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/eyepetater_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_person_play"
                app:layout_constraintBottom_toBottomOf="@id/iv_new_cover_item_item"
                app:layout_constraintEnd_toEndOf="@id/iv_new_cover_item_item"
                app:layout_constraintStart_toStartOf="@id/iv_new_cover_item_item"
                app:layout_constraintTop_toTopOf="@id/iv_new_cover_item_item" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv1_new_item_item"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:layout_constraintDimensionRatio="W,1:5"
        app:layout_constraintTop_toBottomOf="@id/cv_new_item_item">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_new_author_cover_item_item"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="10dp"
                android:padding="2dp"
                android:src="@drawable/eyepetater"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="W,1:1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/round"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/tv_new_title_item_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="测试测试"
                android:textColor="#000000"
                android:textSize="15sp"
                app:layout_constraintStart_toEndOf="@id/iv_new_author_cover_item_item"
                app:layout_constraintTop_toTopOf="@+id/iv_new_author_cover_item_item" />

            <TextView
                android:id="@+id/tv_new_author_name_item_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="测试测试"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="@id/tv_new_title_item_item"
                app:layout_constraintTop_toBottomOf="@+id/tv_new_title_item_item" />

            <TextView
                android:id="@+id/tv_new_label_item_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="#标签"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/tv_new_author_name_item_item"
                app:layout_constraintTop_toTopOf="@+id/tv_new_author_name_item_item" />

            <TextView
                android:id="@+id/tv_new_duration_item_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="114:00"
                android:textColor="#808080"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/tv_new_label_item_item"
                app:layout_constraintTop_toTopOf="@+id/tv_new_label_item_item" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>