<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragment.WorkFragment">

    <TextView
        android:id="@+id/tv_work_default"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="作品：114"
        app:layout_constraintTop_toTopOf="parent"
        />
    <View
        android:id="@+id/divider_work_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="5dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tv_work_default" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_work_default"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider_work_top"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="0dp" />


</androidx.constraintlayout.widget.ConstraintLayout>