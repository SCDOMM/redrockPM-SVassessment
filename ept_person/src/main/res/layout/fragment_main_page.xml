<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tv_main_page_recent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="最近更新"
            android:textColor="#000000"
            android:textSize="13dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/divider_main_page_top"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="5dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tv_main_page_recent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_creator_recent"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:orientation="horizontal"
            app:layout_constraintDimensionRatio="W,5:16"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider_main_page_top" />

        <TextView
            android:id="@+id/tv_main_page_popular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="最近更新"
            android:textColor="#000000"
            android:textSize="13dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/rv_creator_recent" />

        <View
            android:id="@+id/divider_main_page_middle"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="5dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tv_main_page_popular" />

        <LinearLayout
            android:id="@+id/ll_creator_popular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider_main_page_middle" >




        </LinearLayout>

        <View
            android:id="@+id/divider_main_page_bottom"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="5dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/ll_creator_popular" />

        <TextView
            android:id="@+id/tv_main_page_album"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="专辑"
            android:textColor="#000000"
            android:textSize="13dp"
            app:layout_constraintTop_toBottomOf="@id/divider_main_page_bottom"
            app:layout_constraintStart_toStartOf="parent"
            />
        <View
            android:id="@+id/divider_main_page_album"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FFFFFF"
            android:layout_marginVertical="5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_main_page_album"
            />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_main_page_album"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/divider_main_page_album"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>