<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    >

    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv_result_articles_item"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="W,3:8"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:strokeWidth="0.5dp"
            app:cardCornerRadius="10dp"
            app:strokeColor="#E0E0E0"
            >

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_result_articles_cover_item"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/eyepetater"
                app:layout_constraintDimensionRatio="W,1:1"
                app:shapeAppearanceOverlay="@style/roundedCorner"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                />

            <TextView
                android:id="@+id/tv_result_articles_title_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:layout_weight="1"
                android:lineSpacingExtra="6dp"
                android:text="标题测试"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                app:layout_constraintStart_toEndOf="@id/iv_result_articles_cover_item"
                app:layout_constraintTop_toTopOf="@id/iv_result_articles_cover_item"
                />
            <TextView
                android:id="@+id/tv_result_articles_interact_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:textSize="16sp"
                android:text="114人点赞|514人收藏"
                app:layout_constraintBottom_toBottomOf="@id/iv_result_articles_cover_item"
                app:layout_constraintStart_toStartOf="@id/tv_result_articles_title_item"
                />
            <TextView
                android:id="@+id/tv_result_articles_desc_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textSize="20sp"
                android:textColor="#1A1A1A"
                android:text="下北泽|田所浩二画"
                app:layout_constraintBottom_toTopOf="@id/tv_result_articles_interact_item"
                app:layout_constraintStart_toStartOf="@id/tv_result_articles_title_item"
                />
            <ImageView
                android:id="@+id/iv_result_articles_stack_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_search_stack"
                android:layout_margin="10dp"
                app:layout_constraintEnd_toEndOf="@id/iv_result_articles_cover_item"
                app:layout_constraintBottom_toBottomOf="parent"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>