<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingHorizontal="16dp"
    tools:context=".SearchActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignItems="center"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp">

            <com.google.android.material.search.SearchBar
                android:id="@+id/search_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="搜索视频、作者、用户及标签"
                app:searchBarBackground="@android:drawable/transparent"
                app:searchBarElevation="0dp"
                app:searchBarStrokeWidth="0dp"
                app:searchIcon="@drawable/ic_search" />

            <TextView
                android:id="@+id/tv_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:text="取消"
                android:textSize="18sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="space-between"
            android:orientation="horizontal"
            android:paddingVertical="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="搜索历史"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_clear_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="删除"
                android:textColor="#0066CC"
                android:textSize="20sp" />
        </LinearLayout>

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/flex_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:flexGapHorizontal="16dp"
            app:flexGapVertical="12dp"
            app:flexWrap="wrap"
            app:justifyContent="flex_start">
        </com.google.android.flexbox.FlexboxLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="32dp"
            android:paddingBottom="20dp"
            android:text="推荐搜索"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/flex_recommend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:flexGapHorizontal="16dp"
            app:flexGapVertical="12dp"
            app:flexWrap="wrap"
            app:justifyContent="flex_start">
        </com.google.android.flexbox.FlexboxLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
