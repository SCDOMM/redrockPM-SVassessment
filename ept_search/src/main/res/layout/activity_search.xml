<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="16dp"
    tools:context=".SearchActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/ll_search_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.search.SearchView
                android:id="@+id/sv_search_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:queryHint="🔍搜索视频、作者、用户及标签"
                app:searchBarElevation="0dp"
                app:searchBarStrokeWidth="0dp"
                app:searchIcon="@drawable/ic_search_search" />

            <TextView
                android:id="@+id/tv_search_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:text="取消"
                android:textSize="18sp" />
        </LinearLayout>

        <View
            android:id="@+id/vl_search_default"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="2dp"
            android:alpha="0.5"
            android:background="#333333"
            android:layout_marginHorizontal="10dp"
            app:layout_constraintTop_toBottomOf="@id/ll_search_1" />

        <TextView
            android:id="@+id/tv_search_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="搜索历史"
            android:textColor="#111111"
            android:textSize="20sp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp"
            app:layout_constraintTop_toBottomOf="@id/vl_search_default"
            app:layout_constraintStart_toStartOf="parent"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="删除"
            android:textColor="#0066CC"
            android:textSize="20sp"
            app:layout_constraintTop_toBottomOf="@id/ll_search_1"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/flex_search_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:flexGapHorizontal="16dp"
            app:flexGapVertical="12dp"
            app:flexWrap="wrap"
            app:justifyContent="flex_start"
            app:layout_constraintTop_toBottomOf="@id/tv_search_history"
            >

        </com.google.android.flexbox.FlexboxLayout>

        <TextView
            android:id="@+id/tv_search_recommend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="10dp"
            android:text="推荐搜索"
            android:textColor="#111111"
            android:textSize="20sp"
            app:layout_constraintTop_toBottomOf="@id/flex_search_history"
            app:layout_constraintStart_toStartOf="parent"
            />

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/flex_search_recommend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:flexGapHorizontal="16dp"
            app:flexGapVertical="12dp"
            app:flexWrap="wrap"
            app:justifyContent="flex_start"
            app:layout_constraintTop_toBottomOf="@id/tv_search_recommend"
            >

        </com.google.android.flexbox.FlexboxLayout>
        <TextView
            android:id="@+id/tv_search_ranking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="32dp"
            android:paddingBottom="20dp"
            android:layout_marginStart="20dp"
            android:text="视频周榜 >"
            android:textColor="#111111"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flex_search_recommend"
            />

        <LinearLayout
            android:id="@+id/ll_search_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="100dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_search_ranking"
            app:layout_constraintTop_toBottomOf="@id/tv_search_ranking">
            <include
                layout="@layout/itemview_ranking"
                />
            <include
                layout="@layout/itemview_ranking"
                />
            <include
                layout="@layout/itemview_ranking"
                />
            <include
                layout="@layout/itemview_ranking"
                />
            <include
                layout="@layout/itemview_ranking"
                />
            <include
                layout="@layout/itemview_ranking"
                />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
