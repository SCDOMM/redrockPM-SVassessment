<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cv_home_item2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="W,9:16"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/iv_home_cover_item2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/eyepetater_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_home_play"
                app:layout_constraintBottom_toBottomOf="@id/iv_home_cover_item2"
                app:layout_constraintEnd_toEndOf="@id/iv_home_cover_item2"
                app:layout_constraintStart_toStartOf="@id/iv_home_cover_item2"
                app:layout_constraintTop_toTopOf="@id/iv_home_cover_item2" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_home_title_item2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="测试测试"
        android:textSize="15sp"
        android:textColor="#000000"
        app:layout_constraintStart_toEndOf="@id/iv_home_default_item2"
        app:layout_constraintTop_toTopOf="@+id/iv_home_default_item2" />

    <TextView
        android:id="@+id/tv_home_author_item2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="测试测试"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#808080"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="@id/tv_home_title_item2"
        app:layout_constraintTop_toBottomOf="@+id/tv_home_title_item2" />

    <TextView
        android:id="@+id/tv_home_label_item2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="#标签"
        android:textColor="#808080"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/tv_home_author_item2"
        app:layout_constraintTop_toTopOf="@+id/tv_home_author_item2" />

    <TextView
        android:id="@+id/tv_home_duration_item2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="114:00"
        android:textColor="#808080"
        android:textSize="13sp"
        app:layout_constraintStart_toEndOf="@id/tv_home_label_item2"
        app:layout_constraintTop_toTopOf="@+id/tv_home_label_item2" />


    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_home_default_item2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="20dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/eyepetater"
        android:padding="2dp"
        app:strokeWidth="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cv_home_item2"
        app:shapeAppearanceOverlay="@style/round" />

    <View
        android:id="@+id/divider_home_default_item2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="15dp"
        android:background="#E0E0E0"

        app:layout_constraintTop_toBottomOf="@+id/iv_home_default_item2"

        />
</androidx.constraintlayout.widget.ConstraintLayout>